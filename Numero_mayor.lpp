real num1, num2

Inicio

    escriba "Ingrese el primer numero: "
    lea num1
    
    escriba "Ingrese el segundo numero: "
    lea num2
    
    si num1 > num2 entonces
        escriba "El mayor es: ", num1
    sino
        si num2 > num1 entonces
            escriba "El mayor es: ", num2
        sino
            escriba "Ambos numeros son iguales"
        fin si
    fin si

Fin